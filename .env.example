PORT=3777
HOST=0.0.0.0

# Local LLM mode: install Ollama and run `ollama pull llama3.1:8b` or another model.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b

# Optional stronger local backend: LM Studio or llama.cpp OpenAI-compatible server.
# LM Studio default server URL is usually http://127.0.0.1:1234/v1.
# LLM_API_KEY can stay blank for local LM Studio/llama.cpp unless you configured one.
# LLM_PROVIDER=openai-compatible
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=qwen3-32b
LLM_API_KEY=

# Optional hosted fallback compatible with OpenAI-style chat completions.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Prefer qobuz, tidal, library, or streaming in AI prompt wording.
STREAMING_SERVICE=qobuz

# Optional but recommended: verify generated tracks against TIDAL before showing them.
TIDAL_VERIFY=true
TIDAL_COUNTRY_CODE=US
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_ACCESS_TOKEN=
TIDAL_FETCH_TIMEOUT_MS=12000
TIDAL_CIRCUIT_FAILURES=3
TIDAL_CIRCUIT_COOLDOWN_MS=45000

# Optional TIDAL profile mixes page.
# This needs a user-profile bearer token; catalog/client-credentials tokens cannot read personal mixes.
TIDAL_PROFILE_MIXES=true
TIDAL_PROFILE_CLIENT_ID=
TIDAL_PROFILE_CLIENT_SECRET=
TIDAL_PROFILE_REDIRECT_URI=http://127.0.0.1:3777/api/tidal/oauth/callback
TIDAL_PROFILE_SCOPES=user.read playlists.read playlists.write recommendations.read collection.read search.read
TIDAL_PROFILE_ACCESS_TOKEN=
TIDAL_PROFILE_REFRESH_TOKEN=
TIDAL_PROFILE_TOKEN_FILE=
TIDAL_PROFILE_MIXES_ENDPOINT=
TIDAL_PROFILE_ARTIST_RADIO_FALLBACK=false
TIDAL_PINNED_MIXES_FILE=
TIDAL_PROFILE_CACHE_MS=300000

# Radio station now-playing artwork.
# Uses the same resolver pattern as RoonPresence: TIDAL/web first, then Discogs/MusicBrainz,
# with optional Spotify artwork if you add Spotify developer credentials.
RADIO_METADATA_LOOKUP=true
RADIO_METADATA_CACHE_MAX=200
RADIO_METADATA_MIN_LOOKUP_INTERVAL_MS=1500
TIDAL_ARTWORK_LOOKUP=true
DISCOGS_LOOKUP=true
SPOTIFY_ARTWORK_LOOKUP=false
SPOTIFY_MARKET=US
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional HQPlayer signal/rate display. The app also tries the standard HQPlayer 5 Desktop path if no command is set.
HQPLAYER_SIGNAL_PATH_PREFIX=poly-sinc-gauss-hires-mp, TPDF, PCM
HQPLAYER_SIGNAL_PATH_STATIC=
HQPLAYER_RATE_COMMAND="C:\Program Files\Signalyst\HQPlayer 5 Desktop\hqp5-control.exe" localhost --state
HQPLAYER_PTY_WORKER=
HQPLAYER_SIGNAL_PATH_POLL_MS=60000

# Rabbit Hole graph enrichment.
# MusicBrainz works without a key. Last.fm and Discogs are optional.
RABBIT_HOLE_MUSICBRAINZ=true
LASTFM_LOOKUP=true
LASTFM_API_KEY=
LASTFM_USERNAME=
LASTFM_HISTORY_LIMIT=200
LASTFM_TOP_ARTIST_LIMIT=50
LASTFM_TOP_ARTIST_PERIOD=12month
LASTFM_TIMEOUT_MS=3500
DISCOGS_TOKEN=
